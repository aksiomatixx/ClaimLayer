# Dependencies
node_modules/
**/node_modules/

# Environment files — never commit secrets
.env
.env.local
.env.test
**/.env
**/.env.local
**/.env.test

# Build output
dist/
build/
.vite/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Generated test PDFs (npm run gen:test-docs) — claim numbers embed the
# current year and dates are relative to generation, so rebuild, don't commit
test-documents/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Test coverage
coverage/

# Editor / IDE
.idea/
.vscode/

# Keys & certificates — never commit
*.pem
*.key
*.crt
*.p12
*.pfx

# Supabase CLI local state
.supabase/
supabase/.branches/
supabase/.temp/
supabase/.env
