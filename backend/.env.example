# ─────────────────────────────────────────────
# HomeCare TPA — Backend Environment Variables
# Copy to .env and fill in values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ── JWT ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── FileHandler Enterprise (JW Software) ─────
# Mock server (backend/mocks/mock_filehandler.py) runs on port 8002
# Real production URL: https://api.jwsoftware.com/filehandler/v1
FILEHANDLER_API_KEY=mock-fh-key
FILEHANDLER_BASE_URL=http://localhost:8002

# ── ADP Workforce Now ─────────────────────────
# Mock server (backend/mocks/mock_adp.py) runs on port 8001
# Real production URLs: https://accounts.adp.com and https://api.adp.com
ADP_CLIENT_ID=mock
ADP_CLIENT_SECRET=mock
ADP_AUTH_URL=http://localhost:8001/auth/oauth/v2/token
ADP_BASE_URL=http://localhost:8001

# ── Anthropic Claude API ──────────────────────
# Required for AI compensability analysis
ANTHROPIC_API_KEY=

# ── Supabase (PostgreSQL) ─────────────────────
# Not required for mock-only testing — claimService uses in-memory store
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Manifest MedEx / DxF ─────────────────────
# Required for M5 (DxF integration)
MANIFEST_MEDEX_API_KEY=

# ── Health Gorilla ───────────────────────────
# Required for M5 (lab subscriptions)
HEALTH_GORILLA_API_KEY=

# ── Enlyte UR Services ───────────────────────
# Required for M6 (utilization review)
ENLYTE_UR_API_KEY=

# ── Lob.com (print/mail) ─────────────────────
# Use test_ prefix key for development (no physical mail sent)
LOB_API_KEY=

# ── M2: OpenAI (Whisper transcription) ───────
# Required for voice intake transcription — get at platform.openai.com
OPENAI_API_KEY=

# ── M2: Twilio (browser voice recording) ─────
# Required for Twilio Client SDK access tokens
# Get credentials at console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_PHONE_NUMBER=

# ── M2: SendGrid (email notifications) ───────
# Required for authorization letters + intake completion emails
SENDGRID_API_KEY=
SENDGRID_TEMPLATE_INTAKE_COMPLETE=

# ── M2: Adjuster contact info ─────────────────
ADJUSTER_NAME=Akash Kumar
ADJUSTER_PHONE=(800) XXX-XXXX
ADJUSTER_EMAIL=akash.kumar@homecaretpa.com

# ── M2: Magic link secret ─────────────────────
# Defaults to JWT_SECRET if unset
MAGIC_LINK_SECRET=

# ── M2: Frontend URL ──────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Webhook Secrets ───────────────────────────
# HMAC secrets for validating inbound webhook payloads
# Leave blank during development — validation is skipped when unset
DXF_WEBHOOK_SECRET=
ENLYTE_WEBHOOK_SECRET=
LOB_WEBHOOK_SECRET=

# HomeCare TPA claim administrator identity (WCIS required)
# Registered with DWC via Trading Partner Profile.
WCIS_CLAIM_ADMIN_FEIN=
WCIS_CLAIM_ADMIN_NAME=HomeCare TPA
WCIS_CLAIM_ADMIN_POSTAL=          # 9-digit ZIP+4 of physical
                                   # adjusting location (DN14, M/F)
WCIS_CLAIM_ADMIN_ADDRESS_LINE1=
WCIS_CLAIM_ADMIN_CITY=
WCIS_CLAIM_ADMIN_STATE=CA

# Active adapter: stub | sftp | vendor
# Default stub. Production requires real adapter.
WCIS_ADAPTER=stub
