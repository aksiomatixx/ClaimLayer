# ─────────────────────────────────────────────
# HomeCare TPA — Backend Environment Variables
# Copy to .env and fill in values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ── JWT ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── FileHandler Enterprise (JW Software) ─────
# Mock server (backend/mocks/mock_filehandler.py) runs on port 8002
# Real production URL: https://api.jwsoftware.com/filehandler/v1
FILEHANDLER_API_KEY=mock-fh-key
FILEHANDLER_BASE_URL=http://localhost:8002

# ── ADP Workforce Now ─────────────────────────
# Mock server (backend/mocks/mock_adp.py) runs on port 8001
# Real production URLs: https://accounts.adp.com and https://api.adp.com
ADP_CLIENT_ID=mock
ADP_CLIENT_SECRET=mock
ADP_AUTH_URL=http://localhost:8001/auth/oauth/v2/token
ADP_BASE_URL=http://localhost:8001

# ── Anthropic Claude API ──────────────────────
# Required for AI compensability analysis
ANTHROPIC_API_KEY=

# ── Supabase (PostgreSQL) ─────────────────────
# Not required for mock-only testing — claimService uses in-memory store
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Manifest MedEx / DxF ─────────────────────
# Required for M5 (DxF integration)
MANIFEST_MEDEX_API_KEY=

# ── Health Gorilla ───────────────────────────
# Required for M5 (lab subscriptions)
HEALTH_GORILLA_API_KEY=

# ── Enlyte UR Services ───────────────────────
# Required for M6 (utilization review)
ENLYTE_UR_API_KEY=

# ── Lob.com (print/mail) ─────────────────────
# Use test_ prefix key for development (no physical mail sent)
LOB_API_KEY=

# ── SendGrid / Twilio ─────────────────────────
# Required for M4 (magic links, SMS notifications)
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Webhook Secrets ───────────────────────────
# HMAC secrets for validating inbound webhook payloads
# Leave blank during development — validation is skipped when unset
DXF_WEBHOOK_SECRET=
ENLYTE_WEBHOOK_SECRET=
LOB_WEBHOOK_SECRET=
